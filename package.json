{
  "name": "illinois-jim-and-the-shrine-of-catastrophe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Illinois Jim and the Shrine of Catastrophe — a mobile-first 2D arcade adventure.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:browser": "vitest run --project browser",
    "test:visual": "vitest run --project browser tests/visual",
    "test:e2e": "playwright test",
    "cap:sync": "cap sync",
    "cap:add:android": "cap add android",
    "cap:run:android": "cap run android",
    "cap:open:android": "cap open android"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@capacitor/cli": "8.4.1",
    "@playwright/test": "1.61.1",
    "@preact/preset-vite": "2.10.5",
    "@types/node": "26.0.1",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "playwright": "1.61.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/core": "8.4.1",
    "preact": "10.29.3"
  }
}
