{
  "name": "illinois-jim-and-the-shrine-of-catastrophe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Illinois Jim and the Shrine of Catastrophe — a mobile-first 2D arcade adventure.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.test.json",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:browser": "vitest run --project browser",
    "test:visual": "vitest run --project browser tests/visual",
    "test:e2e": "playwright test",
    "cap:sync": "cap sync",
    "cap:add:android": "cap add android",
    "cap:run:android": "cap run android",
    "cap:open:android": "cap open android",
    "assets:kenney": "node scripts/copy-kenney-assets.mjs",
    "assets:itch": "node scripts/fetch-itch-assets.mjs",
    "assets:gen": "node scripts/genai-assets.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@capacitor/cli": "8.4.1",
    "@google/genai": "^2.10.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "4.1.9",
    "playwright": "1.61.1",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "dependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "8.4.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/jersey-15": "^5.2.8",
    "@pixi/react": "^8.0.5",
    "@pixi/tilemap": "^5.0.2",
    "@xstate/react": "^6.1.0",
    "koota": "^0.6.6",
    "nanoid": "^5.1.16",
    "pixi.js": "^8.19.0",
    "popmotion": "^11.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "seedrandom": "^3.0.5",
    "xstate": "^5.32.2",
    "yuka": "^0.7.8",
    "zod": "^4.4.3"
  }
}
