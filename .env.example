# Asset-pipeline credentials. Copy to .env (gitignored) to enable the
# credentialed asset scripts. Kenney CC0 copy (assets:kenney) needs neither.

# itch.io API key — enables `pnpm assets:itch` to download owned packs.
# Get it at https://itch.io/user/settings/api-keys
ITCH_API_KEY=

# Google Gemini API key — enables `pnpm assets:gen` to generate original
# Illinois-Jim sprites + branding art. https://aistudio.google.com/apikey
GEMINI_API_KEY=
