# Dead level reference art: Gemini 2D prop/npc images that prep-level regenerates
# but the runtime never loads (props/NPCs render from baked-3D sprites — see
# src/render/levels/fromLevel.ts ART_TO_BAKED_PROP). Only the parallax + ground
# layers in these dirs are runtime assets and stay tracked; this ignores the rest.
public/assets/levels/*/giant-root-platform.webp
public/assets/levels/*/vine-bridge.webp
public/assets/levels/*/strangler-fig-platform.webp
public/assets/levels/*/mushroom-shelf.webp
public/assets/levels/*/canopy-walkway.webp
public/assets/levels/*/collapsing-log.webp
public/assets/levels/*/ancient-stone-foundation.webp
public/assets/levels/*/guardian-npc.webp
public/assets/levels/*/carnivorous-plant.webp
public/assets/levels/*/canopy-panther.webp
public/assets/levels/*/glow-fruit.webp
public/assets/levels/*/jungle-thorns.webp
public/assets/levels/*/vine-tangle-gate.webp
public/assets/levels/*/jungle-weight-lever.webp
public/assets/levels/*/jungle-totem.webp
public/assets/levels/*/golden-orchid.webp
public/assets/levels/*/jungle-urn.webp

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Generated assets cache
.assets-cache/

# Local-only reference + downloaded raw assets (POC, itch.io downloads, scratch).
# Processed/optimized assets live under src/ or public/ and ARE tracked.
raw-assets/

# vitest-browser proof screenshots (re-derivable)
tests/browser/__screenshots__/
tests/browser/*.png

# Claude task-batch local cache (machine-local, re-derivable)
.claude/state/

# Model viewer working copies (regenerated by scripts/viewer-manifest.ts from raw-assets/models)
dev/viewer/models/
dev/viewer/models.json
